generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum MaterialType {
  VIDEO
  NOTE
}

enum PaymentMethod {
  BKASH
  NAGAD
  BANK
}

enum PurchaseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommissionStatus {
  PAID
  UNPAID
}

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  password       String
  role           Role      @default(STUDENT)
  commissionRate Float?    // Admin sets this when adding a teacher
  phone          String?
  address        String?
  profilePicture String?   // Base64 encoded image string
  currentSessionId String? // Used to prevent multi-device logins
  lastLoginDevice String?
  lastLoginDate  DateTime?
  loginHistory   Json?     // Array of recent logins { device, date }
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  materials      Material[]
  purchases      Purchase[]
  reviewsLeft    Review[]    @relation("StudentReviews")
  reviewsReceived Review[]   @relation("TeacherReviews")
  commissions    Commission[]
  educations     Education[]
  progresses     Progress[]
  questions      Question[]  @relation("StudentQuestions")
  answers        Answer[]
}

model MainCourse {
  id        String    @id @default(uuid())
  name      String    @unique
  coreSubjects CoreSubject[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CoreSubject {
  id           String      @id @default(uuid())
  name         String
  mainCourseId String
  mainCourse   MainCourse  @relation(fields: [mainCourseId], references: [id])
  subjects     Subject[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Subject {
  id            String      @id @default(uuid())
  name          String
  description   String?     @db.Text
  code          String      @unique
  price         Float
  coreSubjectId String
  coreSubject   CoreSubject @relation(fields: [coreSubjectId], references: [id])
  sections      Section[]
  purchases     Purchase[]
  reviews       Review[]
  questions     Question[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Section {
  id        String     @id @default(uuid())
  title     String
  subjectId String
  subject   Subject    @relation(fields: [subjectId], references: [id])
  materials Material[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Material {
  id         String       @id @default(uuid())
  title      String
  type       MaterialType
  url        String
  teacherId  String
  teacher    User         @relation(fields: [teacherId], references: [id])
  sectionId  String
  section    Section      @relation(fields: [sectionId], references: [id])
  isPublic   Boolean      @default(false)
  progresses Progress[]
  questions  Question[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Purchase {
  id            String         @id @default(uuid())
  studentId     String
  student       User           @relation(fields: [studentId], references: [id])
  subjectId     String
  subject       Subject        @relation(fields: [subjectId], references: [id])
  voucherCode   String
  paymentMethod PaymentMethod
  status        PurchaseStatus @default(PENDING)
  couponId      String?
  coupon        Coupon?        @relation(fields: [couponId], references: [id])
  discountAmount Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  commissions   Commission[]
}

model Review {
  id           String   @id @default(uuid())
  rating       Int      // 1 to 5
  comment      String
  teacherReply String?
  studentId    String
  student      User     @relation("StudentReviews", fields: [studentId], references: [id])
  teacherId    String
  teacher      User     @relation("TeacherReviews", fields: [teacherId], references: [id])
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Education {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  degree       String
  major        String?
  institution  String
  passingYear  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Commission {
  id         String           @id @default(uuid())
  teacherId  String
  teacher    User             @relation(fields: [teacherId], references: [id])
  purchaseId String
  purchase   Purchase         @relation(fields: [purchaseId], references: [id])
  amount     Float
  status     CommissionStatus @default(UNPAID)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

// === NEW MODELS FOR PHASE 3, 4, 5 ===

model Progress {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  completed  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, materialId])
}

model Question {
  id         String   @id @default(uuid())
  title      String?
  body       String   @db.Text
  studentId  String
  student    User     @relation("StudentQuestions", fields: [studentId], references: [id])
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  materialId String?
  material   Material? @relation(fields: [materialId], references: [id])
  answers    Answer[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Answer {
  id         String   @id @default(uuid())
  body       String   @db.Text
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Coupon {
  id                 String   @id @default(uuid())
  code               String   @unique
  discountPercentage Float
  validUntil         DateTime?
  isActive           Boolean  @default(true)
  purchases          Purchase[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

